{
  "name": "minigateway",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "type": "module",
  "scripts": {
    "check": "vp check",
    "test": "vp test",
    "build": "vp run build",
    "ready": "vp check && vp test && vp run build",
    "dev": "vp run website#dev",
    "e2e:smoke": "bash ./scripts/e2e-smoke.sh",
    "prepare": "vp config",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:check": "vp check && vp test && vp run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "vite-plus": "0.1.14"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
