{
  "name": "@minigateway/cli",
  "version": "0.1.2",
  "description": "API Proxy Engine CLI - A programmable API gateway based on Hono",
  "homepage": "https://github.com/luozhouyang/minigateway/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/luozhouyang/minigateway/issues"
  },
  "license": "MIT",
  "author": "Luo Zhou Yang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luozhouyang/minigateway.git",
    "directory": "packages/cli"
  },
  "bin": {
    "minigateway": "./dist/index.mjs",
    "proxy-engine": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "vp pack src/cli/index.ts",
    "bundle": "node ./scripts/build.mjs",
    "dev": "vp pack --watch src/cli/index.ts",
    "prepack": "node ./scripts/build.mjs",
    "test": "vp test",
    "check": "vp check",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@minigateway/core": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "typescript": "^5.9.3",
    "vite-plus": "0.1.14"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
